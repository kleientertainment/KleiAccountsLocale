msgstr "لقد أرسلت توصيتك بنجاح لـ <b>{{ .Data.ReferredCreator }}</b>!"

msgid "Recommend a creator that you think would be a good fit for the program. <a href=\"https://support.klei.com/hc/en-us/articles/44019795944084-Creator-Recommendations\" target=\"_blank\" rel=\"noopener noreferrer\">(Click for Details)</a>"
msgstr "رشح مبدعًا ترى أنه مناسب للبرنامج. <a href=\"https://support.klei.com/hc/en-us/articles/44019795944084-Creator-Recommendations\" target=\"_blank\" rel=\"noopener noreferrer\">(انقر للتفاصيل)</a>"

msgid "Recommend a creator"
msgstr "رشح مبدعًا"
