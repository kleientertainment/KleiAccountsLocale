msgstr "حذف تقدمي في ألعاب Klei"

msgid "Delete all the items in my game inventory"
msgstr "حذف جميع العناصر في مخزون لعبتي"

msgid "Delete items from my Steam inventory, including purchased items"
msgstr "حذف العناصر من مخزون Steam الخاص بي، بما في ذلك العناصر المشتراة"

msgid "I do not want to play Don’t Starve Together anymore"
msgstr "لا أريد لعب Don’t Starve Together بعد الآن"

msgid "I do not want to play Hot Lava anymore"
msgstr "لا أريد لعب Hot Lava بعد الآن"

msgid "Ban my {{.PlatformName}} account from playing Klei games for a MINIMUM of 30 days"
msgstr "حظر حسابي على {{.PlatformName}} من لعب ألعاب Klei لمدة لا تقل عن 30 يومًا"

msgid "Confirm Deletion"
msgstr "تأكيد الحذف"

msgid "Please type in “delete my account” but in UPPERCASE letters, to confirm:"
msgstr "يرجى كتابة “delete my account” بأحرف كبيرة لتأكيد العملية:"

