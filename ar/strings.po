msgstr "رسالة من Klei:"

msgid "Already made a submission? Check the status of your submission <a href=\"https://accounts.klei.com/account/fanartevent/status\">here</a>"
msgstr "هل أرسلت مشاركة بالفعل؟ تحقق من حالة إرسالك <a href=\"https://accounts.klei.com/account/fanartevent/status\">هنا</a>"

msgid "Event Rules:"
msgstr "قواعد الفعالية:"

msgid "I agree to abide by the event rules."
msgstr "أوافق على الالتزام بقواعد الفعالية."

msgid "Share Image?"
msgstr "مشاركة الصورة؟"

msgid "I agree to share my image and message publicly on the event page."
msgstr "أوافق على مشاركة صورتي ورسالتي علنًا في صفحة الفعالية."

msgid "Message"
msgstr "الرسالة"

msgid "Approved"
msgstr "مقبول"

